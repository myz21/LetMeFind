{
  "name": "letmefind-video",
  "private": true,
  "version": "0.3.0",
  "type": "module",
  "scripts": {
    "copy:generate": "node --env-file=.env scripts/generate-copy.mjs",
    "tts:generate": "node --env-file=.env scripts/generate-tts.mjs",
    "remotion:preview": "npm run tts:generate && remotion studio src/index.ts",
    "remotion:render:demo": "remotion render src/index.ts LetMeFindDemo out/letmefind_demo_youtube.mp4 --log=verbose",
    "render:demo": "npm run copy:generate && npm run tts:generate && npm run remotion:render:demo"
  },
  "dependencies": {
    "@remotion/cli": "^4.0.0",
    "@remotion/google-fonts": "^4.0.0",
    "@remotion/media-utils": "^4.0.0",
    "@remotion/transitions": "^4.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "typescript": "^5.6.0"
  }
}
